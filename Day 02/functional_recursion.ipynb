   "source": [
    "# sum of n natural numbers [parameterized way]\n",
    "def func(current_sum, n, i):\n",
    "    if i > n:\n",
    "        print(f\"The total sum is: {current_sum}\")\n",
    "        return\n",
    "    func(current_sum + i, n, i + 1)\n",
    "\n",
    "n = int(input(\"Enter n: \"))\n",
    "func(0, n, 1)"
   ]
  }
 ],
